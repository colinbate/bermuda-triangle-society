---

---

<form
    method="post"
    action="https://gaggle.email/join/bermuda-triangle-society@gaggle.email"
    class="gaggle-signup flex flex-col sm:flex-row gap-3"
>
    <div class="flex-1">
        <label for="gaggle-name" class="sr-only">Name</label>
        <input
            id="gaggle-name"
            name="name"
            type="text"
            placeholder="Your name"
            required
            class="w-full px-4 py-3 rounded-lg border border-mystic-200 dark:border-mystic-700 bg-white dark:bg-mystic-900 text-mystic-900 dark:text-mystic-100 placeholder-mystic-400 dark:placeholder-mystic-500 focus:outline-none focus:ring-2 focus:ring-bermuda-500 focus:border-transparent transition-colors"
        />
    </div>
    <div class="flex-1">
        <label for="gaggle-email" class="sr-only">Email address</label>
        <input
            id="gaggle-email"
            name="email"
            type="email"
            placeholder="Email address"
            required
            class="w-full px-4 py-3 rounded-lg border border-mystic-200 dark:border-mystic-700 bg-white dark:bg-mystic-900 text-mystic-900 dark:text-mystic-100 placeholder-mystic-400 dark:placeholder-mystic-500 focus:outline-none focus:ring-2 focus:ring-bermuda-500 focus:border-transparent transition-colors"
        />
    </div>
    <div>
        <button
            type="submit"
            class="w-full sm:w-auto btn btn-link px-6 py-3 whitespace-nowrap"
        >
            <i class="fa-solid fa-sharp fa-paper-plane mr-2"></i>
            Join Group
        </button>
    </div>
</form>
