---
import Layout from "../layouts/Layout.astro";
import ArchiveSignup from "../components/ArchiveSignup.astro";

const joinStatus = Astro.url.searchParams.get("join");
---

<Layout
    title="Join The Archive"
    description="Request access to The Archive, the Bermuda Triangle Society's discussion space for members and readers."
>
    <!-- Page Header -->
    <section
        class="bg-linear-to-b from-mystic-900 to-mystic-800 text-white py-16 md:py-20 relative overflow-hidden"
    >
        <!-- Decorative background -->
        <div
            class="absolute inset-0 bg-stars opacity-20 pointer-events-none"
            aria-hidden="true"
        >
        </div>
        <div
            class="absolute top-1/3 left-1/4 w-64 h-64 bg-bermuda-500/10 rounded-full blur-3xl pointer-events-none"
            aria-hidden="true"
        >
        </div>

        <div class="max-w-4xl mx-auto px-4 text-center relative">
            <span
                class="inline-flex items-center gap-2 text-bermuda-400 text-sm font-semibold uppercase tracking-wide mb-4"
            >
                <i class="fa-solid fa-sharp fa-box-archive"></i>
                The Archive
            </span>
            <h1
                class="text-4xl md:text-5xl font-display font-bold text-white mb-6"
            >
                Join The Archive
            </h1>
            <p class="text-xl text-mystic-200 max-w-2xl mx-auto">
                Request access to the Bermuda Triangle Society's discussion
                space for book talk, session threads, and member
                recommendations.
            </p>
        </div>
    </section>

    <!-- Main Content -->
    <section class="py-16 md:py-20 transition-colors duration-300">
        <div class="max-w-3xl mx-auto px-4">
            <!-- What Is This? -->
            <div class="card p-8 md:p-10 mb-10">
                <h2
                    class="text-2xl font-display font-bold text-mystic-900 dark:text-mystic-100 mb-4 flex items-center gap-3"
                >
                    <span class="text-bermuda-500"
                        ><i class="fa-solid fa-sharp fa-comments"></i></span
                    >
                    What Is The Archive?
                </h2>
                <div
                    class="space-y-4 text-mystic-700 dark:text-mystic-300 text-lg leading-relaxed"
                >
                    <p>
                        The Archive is the Bermuda Triangle Society's
                        <strong class="text-mystic-900 dark:text-mystic-100"
                            >member discussion space</strong
                        >. It's a place to share book recommendations, chat
                        about what you're reading, follow session discussions,
                        and keep track of the ideas that surface between our
                        monthly meetings.
                    </p>
                    <p>
                        Instead of a mailing list, The Archive gives us a
                        quieter home for threaded conversations. You can browse
                        discussions at your own pace, follow the topics you care
                        about, and receive email updates when there is something
                        new for you.
                    </p>
                    <p>
                        Joining is completely <strong
                            class="text-mystic-900 dark:text-mystic-100"
                            >optional</strong
                        >. You're welcome at our meetings whether you're in The
                        Archive or not. This is simply an extra way to stay in
                        touch if you'd like to.
                    </p>
                </div>
            </div>

            <!-- Signup Form -->
            <div
                class="card p-8 md:p-10 mb-10 bg-linear-to-br from-mystic-50 to-bermuda-50 dark:from-mystic-900 dark:to-mystic-950"
            >
                <h2
                    class="text-2xl font-display font-bold text-mystic-900 dark:text-mystic-100 mb-2 text-center"
                >
                    Sign Up
                </h2>
                <p
                    class="text-mystic-600 dark:text-mystic-400 mb-8 text-center"
                >
                    Enter your name and email to request Archive access. You'll
                    receive a sign-in link once your account is ready.
                </p>

                {
                    joinStatus === "invalid" && (
                        <div class="mb-6 rounded-lg bg-lantern-100 dark:bg-lantern-900/40 border border-lantern-300 dark:border-lantern-700 px-4 py-3 text-lantern-900 dark:text-lantern-200 text-sm">
                            <i class="fa-solid fa-sharp fa-triangle-exclamation mr-2" />
                            Please enter a valid email address.
                        </div>
                    )
                }

                {
                    joinStatus === "closed" && (
                        <div class="mb-6 rounded-lg bg-mystic-100 dark:bg-mystic-800 border border-mystic-200 dark:border-mystic-700 px-4 py-3 text-mystic-700 dark:text-mystic-200 text-sm">
                            <i class="fa-solid fa-sharp fa-circle-info mr-2" />
                            Sign up is currently closed. Please check back soon.
                        </div>
                    )
                }

                <ArchiveSignup />

                <p
                    class="mt-6 text-sm text-mystic-500 dark:text-mystic-400 text-center flex items-start gap-1.5 justify-center max-w-md mx-auto"
                >
                    <i
                        class="fa-solid fa-sharp fa-circle-info text-bermuda-500 mt-0.5 shrink-0"
                    ></i>
                    <span>
                        This is <strong>not</strong> the RSVP for our monthly meetings.
                        This requests access to The Archive only. However, members
                        can RSVP to events directly from The Archive. To register
                        publicly for a session, visit the current
                        <a
                            href="/sessions"
                            class="text-bermuda-600 dark:text-bermuda-400 hover:underline"
                            >session page</a
                        >.
                    </span>
                </p>
            </div>

            <!-- What to Expect -->
            <div class="card p-8 md:p-10 mb-10">
                <h2
                    class="text-2xl font-display font-bold text-mystic-900 dark:text-mystic-100 mb-6 flex items-center gap-3"
                >
                    <span class="text-lantern-500"
                        ><i class="fa-solid fa-sharp fa-lightbulb"></i></span
                    >
                    What to Expect
                </h2>
                <div class="grid sm:grid-cols-2 gap-6">
                    <div class="flex gap-3">
                        <span class="text-bermuda-500 text-lg shrink-0"
                            ><i class="fa-solid fa-sharp fa-book-open"
                            ></i></span
                        >
                        <div>
                            <h3
                                class="font-semibold text-mystic-900 dark:text-mystic-100 mb-1 text-base"
                            >
                                Book Talk
                            </h3>
                            <p
                                class="text-sm text-mystic-600 dark:text-mystic-400"
                            >
                                Share what you're reading, ask for
                                recommendations, or discuss the current theme.
                            </p>
                        </div>
                    </div>
                    <div class="flex gap-3">
                        <span class="text-bermuda-500 text-lg shrink-0"
                            ><i class="fa-solid fa-sharp fa-bell"></i></span
                        >
                        <div>
                            <h3
                                class="font-semibold text-mystic-900 dark:text-mystic-100 mb-1 text-base"
                            >
                                Session Threads
                            </h3>
                            <p
                                class="text-sm text-mystic-600 dark:text-mystic-400"
                            >
                                Follow session threads, theme votes, and the
                                conversations that continue after we meet.
                            </p>
                        </div>
                    </div>
                    <div class="flex gap-3">
                        <span class="text-bermuda-500 text-lg shrink-0"
                            ><i class="fa-solid fa-sharp fa-users"></i></span
                        >
                        <div>
                            <h3
                                class="font-semibold text-mystic-900 dark:text-mystic-100 mb-1 text-base"
                            >
                                Community Chat
                            </h3>
                            <p
                                class="text-sm text-mystic-600 dark:text-mystic-400"
                            >
                                A friendly space to chat with other members
                                about all things speculative fiction without
                                everything becoming one long email thread.
                            </p>
                        </div>
                    </div>
                    <div class="flex gap-3">
                        <span class="text-bermuda-500 text-lg shrink-0"
                            ><i class="fa-solid fa-sharp fa-volume-low"
                            ></i></span
                        >
                        <div>
                            <h3
                                class="font-semibold text-mystic-900 dark:text-mystic-100 mb-1 text-base"
                            >
                                At Your Pace
                            </h3>
                            <p
                                class="text-sm text-mystic-600 dark:text-mystic-400"
                            >
                                Email notifications are there when you want
                                them, but The Archive is built for checking in
                                at your own pace.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- FAQ Section -->
            <div class="mb-10">
                <h2
                    class="text-2xl font-display font-bold text-mystic-900 dark:text-mystic-100 mb-6 text-center"
                >
                    Frequently Asked Questions
                </h2>

                <div class="space-y-4">
                    <details class="card p-4 group">
                        <summary
                            class="font-semibold text-mystic-800 dark:text-mystic-200 cursor-pointer flex items-center justify-between"
                        >
                            Does joining The Archive register me for the monthly
                            meeting?
                            <span
                                class="text-mystic-300 group-open:rotate-180 transition-transform"
                                ><i class="fa-solid fa-sharp fa-chevron-down"
                                ></i></span
                            >
                        </summary>
                        <p
                            class="mt-3 text-mystic-600 dark:text-mystic-300 text-sm"
                        >
                            No. The Archive is separate from monthly session
                            RSVPs. To RSVP for a specific session, use the
                            signup link on the
                            <a
                                href="/sessions"
                                class="text-bermuda-600 dark:text-bermuda-400 hover:underline"
                                >session page</a
                            >. You're welcome at meetings whether or not you're
                            in The Archive.
                        </p>
                    </details>

                    <details class="card p-4 group">
                        <summary
                            class="font-semibold text-mystic-800 dark:text-mystic-200 cursor-pointer flex items-center justify-between"
                        >
                            Who can see what I post?
                            <span
                                class="text-mystic-300 group-open:rotate-180 transition-transform"
                                ><i class="fa-solid fa-sharp fa-chevron-down"
                                ></i></span
                            >
                        </summary>
                        <p
                            class="mt-3 text-mystic-600 dark:text-mystic-300 text-sm"
                        >
                            Posts in The Archive are visible to other approved
                            members. It is a shared society space rather than a
                            private inbox, so keep things friendly, thoughtful,
                            and in the spirit of the Code of Conduct.
                        </p>
                    </details>

                    <details class="card p-4 group">
                        <summary
                            class="font-semibold text-mystic-800 dark:text-mystic-200 cursor-pointer flex items-center justify-between"
                        >
                            Can I control email notifications?
                            <span
                                class="text-mystic-300 group-open:rotate-180 transition-transform"
                                ><i class="fa-solid fa-sharp fa-chevron-down"
                                ></i></span
                            >
                        </summary>
                        <p
                            class="mt-3 text-mystic-600 dark:text-mystic-300 text-sm"
                        >
                            Yes. The Archive can send email for sign-in links,
                            replies, followed discussions, and digests, but you
                            can adjust notification preferences from your
                            account settings.
                        </p>
                    </details>

                    <details class="card p-4 group">
                        <summary
                            class="font-semibold text-mystic-800 dark:text-mystic-200 cursor-pointer flex items-center justify-between"
                        >
                            Is this a newsletter?
                            <span
                                class="text-mystic-300 group-open:rotate-180 transition-transform"
                                ><i class="fa-solid fa-sharp fa-chevron-down"
                                ></i></span
                            >
                        </summary>
                        <p
                            class="mt-3 text-mystic-600 dark:text-mystic-300 text-sm"
                        >
                            No. The Archive is a discussion space. Announcements
                            may appear there, but the main point is
                            conversation: members can start threads, reply, and
                            follow the topics they care about.
                        </p>
                    </details>

                    <details class="card p-4 group">
                        <summary
                            class="font-semibold text-mystic-800 dark:text-mystic-200 cursor-pointer flex items-center justify-between"
                        >
                            Do I have to be a regular meeting attendee to join?
                            <span
                                class="text-mystic-300 group-open:rotate-180 transition-transform"
                                ><i class="fa-solid fa-sharp fa-chevron-down"
                                ></i></span
                            >
                        </summary>
                        <p
                            class="mt-3 text-mystic-600 dark:text-mystic-300 text-sm"
                        >
                            Not at all. If you're interested in science fiction
                            and fantasy and want to be part of the community,
                            you're welcome here—even if you can't always make it
                            to meetings in person or live off-island.
                        </p>
                    </details>

                    <details class="card p-4 group">
                        <summary
                            class="font-semibold text-mystic-800 dark:text-mystic-200 cursor-pointer flex items-center justify-between"
                        >
                            Who runs The Archive?
                            <span
                                class="text-mystic-300 group-open:rotate-180 transition-transform"
                                ><i class="fa-solid fa-sharp fa-chevron-down"
                                ></i></span
                            >
                        </summary>
                        <p
                            class="mt-3 text-mystic-600 dark:text-mystic-300 text-sm"
                        >
                            The Archive is managed by Colin Bate, creator and
                            Head Archivist of the Bermuda Triangle Society. Our
                            <a
                                href="/conduct"
                                class="text-bermuda-600 dark:text-bermuda-400 hover:underline"
                                >Code of Conduct</a
                            > applies here as well.
                        </p>
                    </details>
                </div>
            </div>

            <!-- Contact CTA -->
            <div
                class="text-center p-8 bg-linear-to-r from-mystic-100 to-bermuda-100 dark:from-mystic-800 dark:to-mystic-800 rounded-2xl"
            >
                <span
                    class="text-3xl text-mystic-700 dark:text-mystic-200 mb-4 block"
                    ><i class="fa-solid fa-sharp fa-envelope"></i></span
                >
                <h3
                    class="text-xl font-display font-bold text-mystic-900 dark:text-mystic-100 mb-2"
                >
                    Just Want to Say Hello?
                </h3>
                <p
                    class="text-mystic-700 dark:text-mystic-200 max-w-md mx-auto mb-4"
                >
                    If you'd rather reach out directly without joining The
                    Archive, that's perfectly fine too.
                </p>
                <a href="/contact" class="btn btn-outline">
                    Contact Us
                    <i class="fa-solid fa-sharp fa-arrow-right ml-2"></i>
                </a>
            </div>
        </div>
    </section>
</Layout>
