---
import Layout from "../layouts/Layout.astro";
import GaggleSignup from "../components/GaggleSignup.astro";
---

<Layout
    title="Join the Discussion Group"
    description="Join the Bermuda Triangle Society's email discussion group to stay connected between monthly meetings."
>
    <!-- Page Header -->
    <section
        class="bg-linear-to-b from-mystic-900 to-mystic-800 text-white py-16 md:py-20 relative overflow-hidden"
    >
        <!-- Decorative background -->
        <div
            class="absolute inset-0 bg-stars opacity-20 pointer-events-none"
            aria-hidden="true"
        >
        </div>
        <div
            class="absolute top-1/3 left-1/4 w-64 h-64 bg-bermuda-500/10 rounded-full blur-3xl pointer-events-none"
            aria-hidden="true"
        >
        </div>

        <div class="max-w-4xl mx-auto px-4 text-center relative">
            <span
                class="inline-flex items-center gap-2 text-bermuda-400 text-sm font-semibold uppercase tracking-wide mb-4"
            >
                <i class="fa-solid fa-sharp fa-envelope-open-text"></i>
                Stay Connected
            </span>
            <h1
                class="text-4xl md:text-5xl font-display font-bold text-white mb-6"
            >
                Join the Discussion Group
            </h1>
            <p class="text-xl text-mystic-200 max-w-2xl mx-auto">
                Keep the conversation going between meetings with fellow science
                fiction and fantasy readers.
            </p>
        </div>
    </section>

    <!-- Main Content -->
    <section class="py-16 md:py-20 transition-colors duration-300">
        <div class="max-w-3xl mx-auto px-4">
            <!-- What Is This? -->
            <div class="card p-8 md:p-10 mb-10">
                <h2
                    class="text-2xl font-display font-bold text-mystic-900 dark:text-mystic-100 mb-4 flex items-center gap-3"
                >
                    <span class="text-bermuda-500"
                        ><i class="fa-solid fa-sharp fa-comments"></i></span
                    >
                    What Is This Group?
                </h2>
                <div
                    class="space-y-4 text-mystic-700 dark:text-mystic-300 text-lg leading-relaxed"
                >
                    <p>
                        The Bermuda Triangle Society discussion group is an
                        <strong class="text-mystic-900 dark:text-mystic-100"
                            >email-based community</strong
                        > powered by
                        <a
                            href="https://gaggle.email"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-bermuda-600 dark:text-bermuda-400 hover:underline"
                            >Gaggle Mail</a
                        >. It's a place for members to share book
                        recommendations, chat about what they're reading,
                        discuss upcoming themes, or just connect with fellow
                        readers between our monthly meetings.
                    </p>
                    <p>
                        Think of it as a friendly, low-volume mailing list. When
                        someone sends a message, everyone in the group receives
                        it—and anyone can reply. It's many-to-many conversation,
                        not a one-way newsletter.
                    </p>
                    <p>
                        Joining is completely <strong
                            class="text-mystic-900 dark:text-mystic-100"
                            >optional</strong
                        >. You're welcome at our meetings whether you're on the
                        list or not. This is simply an extra way to stay in
                        touch if you'd like to.
                    </p>
                </div>
            </div>

            <!-- Signup Form -->
            <div
                class="card p-8 md:p-10 mb-10 bg-linear-to-br from-mystic-50 to-bermuda-50 dark:from-mystic-900 dark:to-mystic-950"
            >
                <h2
                    class="text-2xl font-display font-bold text-mystic-900 dark:text-mystic-100 mb-2 text-center"
                >
                    Sign Up
                </h2>
                <p
                    class="text-mystic-600 dark:text-mystic-400 mb-8 text-center"
                >
                    Enter your name and email to join the group. You'll receive
                    a confirmation email to verify your address.
                </p>

                <GaggleSignup />

                <p
                    class="mt-6 text-sm text-mystic-500 dark:text-mystic-400 text-center flex items-start gap-1.5 justify-center max-w-md mx-auto"
                >
                    <i
                        class="fa-solid fa-sharp fa-circle-info text-bermuda-500 mt-0.5 shrink-0"
                    ></i>
                    <span>
                        This is <strong>not</strong> the RSVP for our monthly meetings.
                        This signs you up for the email discussion group only. To
                        register for a session, visit the
                        <a
                            href="/sessions"
                            class="text-bermuda-600 dark:text-bermuda-400 hover:underline"
                            >session page</a
                        >.
                    </span>
                </p>
            </div>

            <!-- What to Expect -->
            <div class="card p-8 md:p-10 mb-10">
                <h2
                    class="text-2xl font-display font-bold text-mystic-900 dark:text-mystic-100 mb-6 flex items-center gap-3"
                >
                    <span class="text-lantern-500"
                        ><i class="fa-solid fa-sharp fa-lightbulb"></i></span
                    >
                    What to Expect
                </h2>
                <div class="grid sm:grid-cols-2 gap-6">
                    <div class="flex gap-3">
                        <span class="text-bermuda-500 text-lg shrink-0"
                            ><i class="fa-solid fa-sharp fa-book-open"
                            ></i></span
                        >
                        <div>
                            <h3
                                class="font-semibold text-mystic-900 dark:text-mystic-100 mb-1 text-base"
                            >
                                Book Talk
                            </h3>
                            <p
                                class="text-sm text-mystic-600 dark:text-mystic-400"
                            >
                                Share what you're reading, ask for
                                recommendations, or discuss the current theme.
                            </p>
                        </div>
                    </div>
                    <div class="flex gap-3">
                        <span class="text-bermuda-500 text-lg shrink-0"
                            ><i class="fa-solid fa-sharp fa-bell"></i></span
                        >
                        <div>
                            <h3
                                class="font-semibold text-mystic-900 dark:text-mystic-100 mb-1 text-base"
                            >
                                Meeting Reminders
                            </h3>
                            <p
                                class="text-sm text-mystic-600 dark:text-mystic-400"
                            >
                                Occasional heads-up about upcoming sessions and
                                theme votes.
                            </p>
                        </div>
                    </div>
                    <div class="flex gap-3">
                        <span class="text-bermuda-500 text-lg shrink-0"
                            ><i class="fa-solid fa-sharp fa-users"></i></span
                        >
                        <div>
                            <h3
                                class="font-semibold text-mystic-900 dark:text-mystic-100 mb-1 text-base"
                            >
                                Community Chat
                            </h3>
                            <p
                                class="text-sm text-mystic-600 dark:text-mystic-400"
                            >
                                A friendly space to chat with other members
                                about all things speculative fiction.
                            </p>
                        </div>
                    </div>
                    <div class="flex gap-3">
                        <span class="text-bermuda-500 text-lg shrink-0"
                            ><i class="fa-solid fa-sharp fa-volume-low"
                            ></i></span
                        >
                        <div>
                            <h3
                                class="font-semibold text-mystic-900 dark:text-mystic-100 mb-1 text-base"
                            >
                                Low Volume
                            </h3>
                            <p
                                class="text-sm text-mystic-600 dark:text-mystic-400"
                            >
                                This isn't a firehose—expect a handful of
                                messages around meeting time, not a flood.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- FAQ Section -->
            <div class="mb-10">
                <h2
                    class="text-2xl font-display font-bold text-mystic-900 dark:text-mystic-100 mb-6 text-center"
                >
                    Frequently Asked Questions
                </h2>

                <div class="space-y-4">
                    <details class="card p-4 group">
                        <summary
                            class="font-semibold text-mystic-800 dark:text-mystic-200 cursor-pointer flex items-center justify-between"
                        >
                            Does joining this group register me for the monthly
                            meeting?
                            <span
                                class="text-mystic-300 group-open:rotate-180 transition-transform"
                                ><i class="fa-solid fa-sharp fa-chevron-down"
                                ></i></span
                            >
                        </summary>
                        <p
                            class="mt-3 text-mystic-600 dark:text-mystic-300 text-sm"
                        >
                            No. This is a separate email discussion group for
                            chatting between meetings. To RSVP for a specific
                            session, use the signup link on the
                            <a
                                href="/sessions"
                                class="text-bermuda-600 dark:text-bermuda-400 hover:underline"
                                >session page</a
                            >. You're welcome at meetings whether or not you're
                            on this list.
                        </p>
                    </details>

                    <details class="card p-4 group">
                        <summary
                            class="font-semibold text-mystic-800 dark:text-mystic-200 cursor-pointer flex items-center justify-between"
                        >
                            If I send a message, does the whole group see it?
                            <span
                                class="text-mystic-300 group-open:rotate-180 transition-transform"
                                ><i class="fa-solid fa-sharp fa-chevron-down"
                                ></i></span
                            >
                        </summary>
                        <p
                            class="mt-3 text-mystic-600 dark:text-mystic-300 text-sm"
                        >
                            Yes. When you reply to a group message or send a new
                            one to the group address, all members receive it.
                            That's the idea—it's a shared conversation, not a
                            private channel. Keep things friendly and on-topic,
                            and it works great.
                        </p>
                    </details>

                    <details class="card p-4 group">
                        <summary
                            class="font-semibold text-mystic-800 dark:text-mystic-200 cursor-pointer flex items-center justify-between"
                        >
                            Can I unsubscribe?
                            <span
                                class="text-mystic-300 group-open:rotate-180 transition-transform"
                                ><i class="fa-solid fa-sharp fa-chevron-down"
                                ></i></span
                            >
                        </summary>
                        <p
                            class="mt-3 text-mystic-600 dark:text-mystic-300 text-sm"
                        >
                            Absolutely. Every message from the group includes an
                            unsubscribe link at the bottom. You can leave at any
                            time with one click—no hard feelings.
                        </p>
                    </details>

                    <details class="card p-4 group">
                        <summary
                            class="font-semibold text-mystic-800 dark:text-mystic-200 cursor-pointer flex items-center justify-between"
                        >
                            Is this a newsletter?
                            <span
                                class="text-mystic-300 group-open:rotate-180 transition-transform"
                                ><i class="fa-solid fa-sharp fa-chevron-down"
                                ></i></span
                            >
                        </summary>
                        <p
                            class="mt-3 text-mystic-600 dark:text-mystic-300 text-sm"
                        >
                            Not exactly. A newsletter is one-way—someone writes,
                            you read. This is a discussion group where anyone
                            can start or join a conversation. Think of it more
                            like a group email thread than a mailing list.
                        </p>
                    </details>

                    <details class="card p-4 group">
                        <summary
                            class="font-semibold text-mystic-800 dark:text-mystic-200 cursor-pointer flex items-center justify-between"
                        >
                            Do I have to be a regular meeting attendee to join?
                            <span
                                class="text-mystic-300 group-open:rotate-180 transition-transform"
                                ><i class="fa-solid fa-sharp fa-chevron-down"
                                ></i></span
                            >
                        </summary>
                        <p
                            class="mt-3 text-mystic-600 dark:text-mystic-300 text-sm"
                        >
                            Not at all. If you're interested in science fiction
                            and fantasy and want to be part of the community,
                            you're welcome here—even if you can't always make it
                            to meetings in person or live off-island.
                        </p>
                    </details>

                    <details class="card p-4 group">
                        <summary
                            class="font-semibold text-mystic-800 dark:text-mystic-200 cursor-pointer flex items-center justify-between"
                        >
                            Who runs the group?
                            <span
                                class="text-mystic-300 group-open:rotate-180 transition-transform"
                                ><i class="fa-solid fa-sharp fa-chevron-down"
                                ></i></span
                            >
                        </summary>
                        <p
                            class="mt-3 text-mystic-600 dark:text-mystic-300 text-sm"
                        >
                            The group is managed by Colin Bate, creator of the
                            Bermuda Triangle Society. Our
                            <a
                                href="/conduct"
                                class="text-bermuda-600 dark:text-bermuda-400 hover:underline"
                                >Code of Conduct</a
                            > applies here as well.
                        </p>
                    </details>
                </div>
            </div>

            <!-- Contact CTA -->
            <div
                class="text-center p-8 bg-linear-to-r from-mystic-100 to-bermuda-100 dark:from-mystic-800 dark:to-mystic-800 rounded-2xl"
            >
                <span
                    class="text-3xl text-mystic-700 dark:text-mystic-200 mb-4 block"
                    ><i class="fa-solid fa-sharp fa-envelope"></i></span
                >
                <h3
                    class="text-xl font-display font-bold text-mystic-900 dark:text-mystic-100 mb-2"
                >
                    Just Want to Say Hello?
                </h3>
                <p
                    class="text-mystic-700 dark:text-mystic-200 max-w-md mx-auto mb-4"
                >
                    If you'd rather reach out directly without joining the
                    group, that's perfectly fine too.
                </p>
                <a href="/contact" class="btn btn-outline">
                    Contact Us
                    <i class="fa-solid fa-sharp fa-arrow-right ml-2"></i>
                </a>
            </div>
        </div>
    </section>
</Layout>
